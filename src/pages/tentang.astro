---
import BaseLayout from "../layouts/BaseLayout.astro";
import MetricCard from "../components/ui/MetricCard.astro";
import StepCard from "../components/ui/StepCard.astro";
import {
  BookOpen, Target, ShieldCheck, Ruler, Eraser,
  Calculator, Scale, TrendingDown, Microscope,
  CheckCircle2, XCircle,
} from "@lucide/astro";
import metricsData from "../data/metrics.json";

const { layer1, layer2 } = metricsData;
---

<BaseLayout title="Panduan & Metodologi" activePage="tentang">

  <!-- PAGE HEADER -->
  <div class="mb-10 fade-in-up">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-base-100 border border-base-300 shadow-sm mb-4">
      <span class="text-primary [&>svg]:w-4 [&>svg]:h-4"><BookOpen /></span>
      <span class="text-xs font-semibold uppercase tracking-wider text-base-content/70">Dokumentasi</span>
    </div>
    <h1 class="text-3xl lg:text-4xl font-bold tracking-tight text-primary">Panduan & Metodologi</h1>
    <p class="text-base text-base-content/60 mt-2 max-w-2xl">
      Penjelasan lengkap mengenai algoritma, pipeline data, dan metrik evaluasi yang digunakan pada sistem ini.
    </p>
  </div>

  <!-- SECTION 1: Arsitektur + Dataset (side by side) -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6 fade-in-up delay-100">
    <!-- Left: Arsitektur & Pipeline -->
    <div class="lg:col-span-2 space-y-6">
      <div class="glass-card rounded-2xl p-6 lg:p-8 hover-lift">
        <h2 class="text-xl font-bold tracking-tight mb-4 flex items-center gap-2">
          <span class="text-accent">01.</span> Arsitektur Two-Layer Clustering
        </h2>
        <p class="text-sm font-medium leading-relaxed text-base-content/70 mb-4">
          Penelitian ini menggunakan pendekatan two-layer clustering untuk mengatasi ketidakseimbangan data yang sangat ekstrem. Dari total 390.167 pelanggan unik, sebanyak 89,2% adalah pembeli satu kali (one-time buyer).
        </p>
        <p class="text-sm font-medium leading-relaxed text-base-content/70">
          Jika klasterisasi dilakukan sekaligus, algoritma akan cenderung menumpuk mayoritas data ke dalam satu klaster raksasa (96% populasi). Oleh karena itu, sistem ini memfilter 42.248 pelanggan Repeat Buyer untuk diproses pada Layer 2 demi menghasilkan pemisahan segmen yang jauh lebih bermakna.
        </p>
      </div>

      <div class="glass-card rounded-2xl p-6 lg:p-8 hover-lift">
        <h2 class="text-xl font-bold tracking-tight mb-4 flex items-center gap-2">
          <span class="text-accent">02.</span> Pipeline Data Science
        </h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-2">
          <StepCard step={1} title="RFM Extraction" description="Kalkulasi fitur numerik Recency, Frequency, Monetary."><Calculator slot="icon" /></StepCard>
          <StepCard step={2} title="Yeo-Johnson" description="Normalisasi distribusi PowerTransformer."><Scale slot="icon" /></StepCard>
          <StepCard step={3} title="UMAP Projection" description="Reduksi dimensi 3D → 2D yang efisien."><TrendingDown slot="icon" /></StepCard>
          <StepCard step={4} title="HDBSCAN" description="Klasterisasi densitas tanpa K-value awal."><Microscope slot="icon" /></StepCard>
        </div>
      </div>
    </div>

    <!-- Right: Dataset Shopee card only -->
    <div>
      <div class="rounded-2xl p-6 hover-lift h-full" style="background: #1a1a1a;">
        <h2 class="text-xs font-bold tracking-widest mb-6 text-white/50 uppercase">Dataset Shopee</h2>
        <div class="space-y-5">
          <div class="flex justify-between items-center pb-4 border-b border-white/10">
            <span class="text-sm text-white/60">Total Baris Mentah</span>
            <span class="font-bold text-white text-lg">742.182</span>
          </div>
          <div class="flex justify-between items-center pb-4 border-b border-white/10">
            <span class="text-sm text-white/60">Transaksi Bersih</span>
            <span class="font-bold text-white text-lg">481.682</span>
          </div>
          <div class="flex justify-between items-center pb-4 border-b border-white/10">
            <span class="text-sm text-white/60">Periode Waktu</span>
            <span class="font-bold text-white text-lg">5 Tahun</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-sm text-white/60">Pelanggan Unik</span>
            <span class="font-bold text-white text-lg">390.167</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 2: Evaluasi Layer 1 vs Layer 2 -->
  <div class="glass-card rounded-2xl p-6 lg:p-8 hover-lift fade-in-up delay-200 mb-6">
    <h2 class="text-xl font-bold tracking-tight mb-2 flex items-center gap-2">
      <span class="text-primary [&>svg]:w-6 [&>svg]:h-6"><TrendingDown /></span>
      Evaluasi Performa Model: Perbandingan Layer
    </h2>
    <p class="text-sm text-base-content/50 mb-8">
      Perbandingan kualitas klasterisasi antara Layer 1 (semua pelanggan) vs Layer 2 (repeat buyer only)
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Layer 1 -->
      <div class="rounded-2xl border-2 border-error/20 bg-error/5 p-6">
        <div class="flex items-center justify-between mb-5">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-error [&>svg]:w-5 [&>svg]:h-5"><XCircle /></span>
              <span class="font-bold text-base">Layer 1: {layer1.label}</span>
            </div>
            <p class="text-xs text-base-content/50">{layer1.description}</p>
          </div>
          <div class="badge badge-error badge-outline text-xs font-bold">Tidak Optimal</div>
        </div>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">DBCV Score</span>
            <div class="flex items-center gap-2">
              <div class="w-24 h-1.5 bg-base-300 rounded-full overflow-hidden">
                <div class="h-full bg-error rounded-full" style={`width: ${(layer1.dbcv * 100).toFixed(1)}%`}></div>
              </div>
              <span class="font-bold text-error text-sm">{layer1.dbcv.toFixed(4)}</span>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Silhouette RFM</span>
            <span class="font-bold text-error text-sm">{layer1.silhouette_rfm.toFixed(4)}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Silhouette UMAP</span>
            <span class="font-bold text-sm">{layer1.silhouette_umap.toFixed(3)}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Cluster Stability</span>
            <span class="font-bold text-sm">{layer1.cluster_stability.toFixed(4)}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Jumlah Klaster</span>
            <span class="font-bold text-sm">{layer1.n_clusters} klaster</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Data Noise</span>
            <span class="font-bold text-warning text-sm">{layer1.noise_pct}%</span>
          </div>
        </div>
      </div>

      <!-- Layer 2 -->
      <div class="rounded-2xl border-2 border-success/30 bg-success/5 p-6">
        <div class="flex items-center justify-between mb-5">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-success [&>svg]:w-5 [&>svg]:h-5"><CheckCircle2 /></span>
              <span class="font-bold text-base">Layer 2: {layer2.label}</span>
            </div>
            <p class="text-xs text-base-content/50">{layer2.description}</p>
          </div>
          <div class="badge badge-success badge-outline text-xs font-bold">Optimal</div>
        </div>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">DBCV Score</span>
            <div class="flex items-center gap-2">
              <div class="w-24 h-1.5 bg-base-300 rounded-full overflow-hidden">
                <div class="h-full bg-success rounded-full" style={`width: ${(layer2.dbcv * 100).toFixed(0)}%`}></div>
              </div>
              <span class="font-bold text-success text-sm">{layer2.dbcv.toFixed(3)}</span>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Silhouette RFM</span>
            <span class="font-bold text-success text-sm">{layer2.silhouette_rfm.toFixed(3)}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Silhouette UMAP</span>
            <span class="font-bold text-success text-sm">{layer2.silhouette_umap.toFixed(3)}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Cluster Stability</span>
            <span class="font-bold text-success text-sm">{layer2.cluster_stability.toFixed(2)}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Jumlah Klaster</span>
            <span class="font-bold text-sm">{layer2.n_clusters} klaster</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Data Noise</span>
            <span class="font-bold text-success text-sm">{layer2.noise_pct}%</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 3: Metric Cards Layer 2 -->
  <div class="glass-card rounded-2xl p-6 lg:p-8 hover-lift fade-in-up delay-300 mb-10">
    <h2 class="text-xs font-bold tracking-widest mb-6 uppercase text-base-content/50">
      Metrik Detail: Layer 2 (Repeat Buyer)
    </h2>
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
      <MetricCard label="DBCV" value="0.789" description="Kualitas pemisahan kepadatan klaster. Mendekati 1.0 = sempurna" highlight={true}><Target slot="icon" /></MetricCard>
      <MetricCard label="Silhouette RFM" value="0.430" description="Validitas jarak antar klaster pada ruang RFM asli"><Ruler slot="icon" /></MetricCard>
      <MetricCard label="Silhouette UMAP" value="0.325" description="Validitas jarak antar klaster pada ruang UMAP"><Ruler slot="icon" /></MetricCard>
      <MetricCard label="Stability" value="0.9092" description="Konsistensi pembentukan klaster terhadap perubahan data" highlight={true}><ShieldCheck slot="icon" /></MetricCard>
      <MetricCard label="Noise" value="0%" description="Proporsi data yang tidak masuk klaster manapun"><Eraser slot="icon" /></MetricCard>
    </div>
  </div>

</BaseLayout>
