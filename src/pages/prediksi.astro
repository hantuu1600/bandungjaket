---
import { Search } from '@lucide/astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import InputForm from '../components/prediksi/InputForm.astro'
import CsvUpload from '../components/prediksi/CsvUpload.astro'
import ResultCard from '../components/prediksi/ResultCard.astro'
---
<BaseLayout title="Simulasi Segmen" activePage="prediksi">
  
  <div class="mb-10 fade-in-up">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-base-100 border border-base-300 shadow-sm mb-4">
      <span class="text-primary [&>svg]:w-4 [&>svg]:h-4"><Search /></span>
      <span class="text-xs font-semibold uppercase tracking-wider text-base-content/70">Interactive Tool</span>
    </div>
    <h1 class="text-3xl lg:text-4xl font-bold tracking-tight text-primary">Klasifikasi Segmen Pelanggan</h1>
    <p class="text-base text-base-content/60 mt-2 max-w-2xl">
      Klasifikasikan profil pelanggan tunggal atau unggah data transaksi massal untuk memetakan kelompok loyalitas pelanggan.
    </p>
  </div>

  <div class="mb-8 fade-in-up delay-100">
    <div role="tablist" class="tabs tabs-boxed bg-base-200/50 p-1 w-full max-w-sm rounded-xl">
      <a id="tab-single" role="tab" class="tab tab-active font-bold rounded-lg h-10 transition-colors">Simulasi Satuan</a>
      <a id="tab-batch" role="tab" class="tab text-base-content/50 font-semibold rounded-lg h-10 hover:text-primary transition-colors">Unggah Batch (CSV)</a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-20 fade-in-up delay-200">
    <!-- Left Column: Inputs -->
    <div class="lg:col-span-5 space-y-6">
      <div id="container-single">
        <InputForm />
      </div>
      <div id="container-batch" class="hidden">
        <CsvUpload />
      </div>
    </div>
    
    <!-- Right Column: Result Panel -->
    <div class="lg:col-span-7">
      <ResultCard />
    </div>
  </div>

</BaseLayout>

<script>
  // Tab Switching Logic
  const tabSingle = document.getElementById('tab-single');
  const tabBatch = document.getElementById('tab-batch');
  const containerSingle = document.getElementById('container-single');
  const containerBatch = document.getElementById('container-batch');

  if (tabSingle && tabBatch && containerSingle && containerBatch) {
    tabSingle.addEventListener('click', () => {
      tabSingle.classList.add('tab-active', 'font-bold');
      tabSingle.classList.remove('text-base-content/50');
      
      tabBatch.classList.remove('tab-active', 'font-bold');
      tabBatch.classList.add('text-base-content/50');
      
      containerSingle.classList.remove('hidden');
      containerBatch.classList.add('hidden');
    });

    tabBatch.addEventListener('click', () => {
      tabBatch.classList.add('tab-active', 'font-bold');
      tabBatch.classList.remove('text-base-content/50');
      
      tabSingle.classList.remove('tab-active', 'font-bold');
      tabSingle.classList.add('text-base-content/50');
      
      containerBatch.classList.remove('hidden');
      containerSingle.classList.add('hidden');
    });
  }
</script>
