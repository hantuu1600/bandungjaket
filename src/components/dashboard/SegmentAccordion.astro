---
import { CheckCircle, Pin } from '@lucide/astro'
import segmentsData from '../../data/segments.json'
const segments = segmentsData.segments
---
<div class="fade-in-up delay-200 mb-12">
  <!-- Table Header (Desktop Only) -->
  <div class="hidden lg:grid grid-cols-6 gap-4 px-8 pb-3 text-[10px] font-bold uppercase tracking-widest text-base-content/50 border-b border-base-300 mr-12">
    <div class="col-span-2">Nama Segmen</div>
    <div>Jumlah Pelanggan</div>
    <div>Median Terakhir Beli</div>
    <div>Median Frekuensi</div>
    <div>Median Total Belanja</div>
  </div>

  <div class="flex flex-col gap-3 mt-4">
    {segments.map((segment) => (
      <div class="collapse collapse-arrow bg-base-100 border border-base-300 shadow-sm rounded-2xl hover:border-primary/30 transition-colors">
        <input type="radio" name="segment-accordion" checked={segment.id === 5} />
        
        <!-- Visible Row -->
        <div class="collapse-title flex flex-col lg:grid lg:grid-cols-6 gap-4 py-4 pl-4 pr-12 lg:py-4 lg:px-6 items-center">
          
          <!-- Name -->
          <div class="col-span-2 flex items-center gap-4 w-full">
            <div class="w-12 h-12 rounded-full flex items-center justify-center border-2 border-white shadow-sm shrink-0" style={`background-color: ${segment.color_dot}20; border-color: ${segment.color_dot};`}>
              <span class="w-3 h-3 rounded-full" style={`background-color: ${segment.color_dot};`}></span>
            </div>
            <div>
              <div class="font-bold text-base text-primary leading-tight">{segment.name}</div>
            </div>
          </div>
          
          <!-- Metrics -->
          <div class="w-full lg:w-auto flex justify-between lg:block border-b border-base-200 lg:border-0 pb-2 lg:pb-0">
            <span class="lg:hidden text-xs font-semibold text-base-content/50 uppercase tracking-wider">Jumlah Pelanggan</span>
            <span class="font-extrabold text-lg">{segment.count.toLocaleString('id-ID')}</span>
          </div>
          
          <div class="w-full lg:w-auto flex justify-between lg:block border-b border-base-200 lg:border-0 pb-2 lg:pb-0">
             <span class="lg:hidden text-xs font-semibold text-base-content/50 uppercase tracking-wider">Terakhir Beli</span>
             <span class="font-medium text-base-content/70">{segment.recency} Hari</span>
          </div>
          
          <div class="w-full lg:w-auto flex justify-between lg:block border-b border-base-200 lg:border-0 pb-2 lg:pb-0">
             <span class="lg:hidden text-xs font-semibold text-base-content/50 uppercase tracking-wider">Frekuensi</span>
             <span class="font-medium text-base-content/70">{segment.frequency}× / Tahun</span>
          </div>
          
          <div class="w-full lg:w-auto flex justify-between lg:block">
             <span class="lg:hidden text-xs font-semibold text-base-content/50 uppercase tracking-wider">Total Belanja</span>
             <span class="font-bold text-primary">Rp {segment.monetary.toLocaleString('id-ID')}</span>
          </div>

        </div>
        
        <!-- Expanded Content -->
        <div class="collapse-content px-6 pb-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-6 border-t border-base-200 mt-2">
            
            <!-- Karakteristik -->
            <div>
              <h4 class="text-[10px] uppercase font-bold tracking-widest text-base-content/50 mb-3 flex items-center gap-2">
                <span class="text-primary [&>svg]:w-4 [&>svg]:h-4"><Pin /></span> Karakteristik Segmen
              </h4>
              <p class="text-sm font-medium leading-relaxed text-base-content/80">{segment.description}</p>
            </div>
            
            <!-- Strategi Marketing -->
            <div class="bg-base-200/50 rounded-xl p-5 border border-base-300">
              <h4 class="text-[10px] uppercase font-bold tracking-widest text-primary mb-4 flex items-center gap-2">
                <span class="text-primary [&>svg]:w-4 [&>svg]:h-4"><CheckCircle /></span> Strategi Marketing
              </h4>
              <ul class="space-y-3">
                {segment.recommendations.map((r) => (
                  <li class="flex items-start gap-3 text-sm text-base-content/80">
                    <span class="text-primary mt-0.5 text-[10px]">●</span>
                    <span class="font-medium">{r}</span>
                  </li>
                ))}
              </ul>
            </div>
            
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
