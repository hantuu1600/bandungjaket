---
import { FileText, Calendar, Repeat, CircleDollarSign, Rocket } from '@lucide/astro'
---
<div class="card glass-card hover-lift shadow-sm">
  <div class="card-body p-6 lg:p-8">
    <div class="flex items-center justify-between mb-8">
      <h3 class="card-title font-bold text-lg tracking-tight">Data Transaksi</h3>
      <div class="w-10 h-10 rounded-full bg-primary/5 flex items-center justify-center text-primary [&>svg]:w-5 [&>svg]:h-5"><FileText /></div>
    </div>

    <div class="space-y-6">
      <div class="form-control">
        <label class="label pb-2">
          <span class="label-text font-bold text-xs uppercase tracking-widest text-base-content/70">Hari Sejak Beli Terakhir (Recency)</span>
        </label>
        <div class="relative">
          <input id="input-recency" type="number" min="1" placeholder="Contoh: 30" class="input input-lg input-bordered w-full bg-base-100/50 pl-12 focus:border-primary transition-colors font-medium" />
          <span class="absolute left-4 top-1/2 -translate-y-1/2 opacity-40 text-primary [&>svg]:w-5 [&>svg]:h-5"><Calendar /></span>
        </div>
      </div>

      <div class="form-control">
        <label class="label pb-2">
          <span class="label-text font-bold text-xs uppercase tracking-widest text-base-content/70">Total Transaksi (Frequency)</span>
        </label>
        <div class="relative">
          <input id="input-frequency" type="number" min="1" placeholder="Contoh: 5" class="input input-lg input-bordered w-full bg-base-100/50 pl-12 focus:border-primary transition-colors font-medium" />
          <span class="absolute left-4 top-1/2 -translate-y-1/2 opacity-40 text-primary [&>svg]:w-5 [&>svg]:h-5"><Repeat /></span>
        </div>
        <!-- Warning -->
        <div id="freq-warning" class="alert alert-warning mt-3 shadow-sm rounded-xl hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
          <span class="text-xs font-semibold leading-relaxed">Pelanggan 1x beli tidak termasuk di model ini.</span>
        </div>
      </div>

      <div class="form-control mb-4">
        <label class="label pb-2">
          <span class="label-text font-bold text-xs uppercase tracking-widest text-base-content/70">Total Belanja (Monetary) Rp</span>
        </label>
        <div class="relative">
          <input id="input-monetary" type="number" min="1000" placeholder="Contoh: 1500000" class="input input-lg input-bordered w-full bg-base-100/50 pl-12 focus:border-primary transition-colors font-medium" />
          <span class="absolute left-4 top-1/2 -translate-y-1/2 opacity-40 text-primary [&>svg]:w-5 [&>svg]:h-5"><CircleDollarSign /></span>
        </div>
      </div>
    </div>

    <div class="card-actions mt-8 block">
      <button id="btn-predict" class="btn btn-primary btn-block btn-lg rounded-xl font-bold shadow-lg shadow-primary/30 group hover:shadow-primary/50 transition-all duration-300">
        <span class="group-hover:scale-105 transition-transform duration-300 flex items-center justify-center gap-2">Cek Status & Rekomendasi <Rocket class="w-5 h-5" /></span>
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const freqInput = document.getElementById('input-frequency') as HTMLInputElement
    const recInput = document.getElementById('input-recency') as HTMLInputElement
    const monInput = document.getElementById('input-monetary') as HTMLInputElement
    const warning   = document.getElementById('freq-warning')
    const btnPredict = document.getElementById('btn-predict') as HTMLButtonElement
    
    if (freqInput && warning) {
      freqInput.addEventListener('input', () => {
        const val = parseInt(freqInput.value)
        warning.classList.toggle('hidden', val !== 1)
      })
    }

    if (btnPredict) {
      btnPredict.addEventListener('click', async () => {
        const recency = parseInt(recInput.value)
        const frequency = parseInt(freqInput.value)
        const monetary = parseFloat(monInput.value)

        if (!recency || !frequency || !monetary) {
          alert('Mohon isi semua data transaksi!')
          return
        }

        // Tampilkan loading state di tombol
        const originalText = btnPredict.innerHTML
        btnPredict.innerHTML = '<span class="loading loading-spinner"></span> Memproses...'
        btnPredict.disabled = true

        try {
          const response = await fetch('https://hantuu16-data-bandungjaket.hf.space/api/predict', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ recency, frequency, monetary })
          })

          if (!response.ok) throw new Error('API Error')
          const result = await response.json()

          // Sembunyikan state kosong
          document.getElementById('result-empty')?.classList.add('hidden')
          
          // Tampilkan state hasil
          const resultSuccess = document.getElementById('result-success')
          if (resultSuccess) {
            resultSuccess.classList.remove('hidden')
            resultSuccess.classList.add('flex')
          }

          // Render hasil dari API ke dalam UI
          const segName = document.getElementById('result-segment-name')
          if (segName) {
             const segmentNames: Record<string, string> = {
               "-1": "Noise / Outlier",
               "0": "Pelanggan Potensial",
               "1": "Pelanggan Dorman",
               "2": "Pelanggan Unggulan",
               "3": "Pelanggan Aktif",
               "4": "Pelanggan Berisiko Berhenti",
               "5": "Pelanggan Bernilai Terancam",
             }
             segName.innerText = segmentNames[String(result.cluster_id)] || `Segmen ${result.cluster_id}`
          }

          const umapX = document.getElementById('result-umap-x')
          const umapY = document.getElementById('result-umap-y')
          if (umapX) umapX.innerText = `X: ${result.umap_x.toFixed(3)}`
          if (umapY) umapY.innerText = `Y: ${result.umap_y.toFixed(3)}`

        } catch (error) {
          alert('Gagal menghubungi API Backend. Pastikan uvicorn sudah berjalan.')
          console.error(error)
        } finally {
          btnPredict.innerHTML = originalText
          btnPredict.disabled = false
        }
      })
    }
  })
</script>
