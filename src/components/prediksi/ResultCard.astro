---
import { ClipboardList } from '@lucide/astro'
---
<div class="card glass-card h-full border-dashed border-2 border-primary/20 relative overflow-hidden group shadow-sm" id="result-container">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  
  <div id="result-empty" class="card-body items-center justify-center p-10 text-center relative z-10 flex flex-col">
    <div class="w-24 h-24 bg-base-100 rounded-full flex items-center justify-center shadow-xl shadow-base-300/50 mb-6 animate-bounce text-primary/40 [&>svg]:w-10 [&>svg]:h-10" style="animation-duration: 3s;">
      <ClipboardList />
    </div>
    
    <h3 class="card-title text-2xl font-bold text-primary mb-2">Menunggu Data...</h3>
    <p class="text-sm font-medium text-base-content/60 max-w-xs leading-relaxed">
      Silakan masukkan data transaksi pelanggan pada form di samping untuk melihat hasil analisis segmen.
    </p>
  </div>

  <!-- Ini template hasil, hidden secara default -->
  <div id="result-success" class="card-body p-8 relative z-10 hidden flex-col items-center justify-center h-full">
    <div class="w-20 h-20 bg-success/10 rounded-full flex items-center justify-center text-success mb-4 shadow-inner shadow-success/20">
      <!-- Menggunakan icon SVG kustom sederhana sebagai pengganti Target agar tidak repot import lucide -->
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
    </div>
    <h4 class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-1">Hasil Klasifikasi</h4>
    <h2 id="result-segment-name" class="text-3xl font-extrabold text-primary mb-6 text-center leading-tight">Nama Segmen</h2>
    
    <div class="w-full bg-base-100 rounded-xl p-5 border border-base-200">
      <h5 class="text-[10px] font-bold uppercase tracking-widest text-base-content/50 mb-2">Titik Koordinat UMAP (2D)</h5>
      <div class="flex justify-between items-center bg-base-200/50 rounded-lg p-3">
        <span class="font-mono text-sm font-semibold text-base-content/70" id="result-umap-x">X: 0.00</span>
        <span class="text-base-content/30">|</span>
        <span class="font-mono text-sm font-semibold text-base-content/70" id="result-umap-y">Y: 0.00</span>
      </div>
    </div>
    <p class="text-[10px] text-base-content/40 mt-6 text-center font-medium">Data diproses secara real-time via API FastAPI <br/>(Pipeline: Yeo-Johnson → UMAP → HDBSCAN)</p>
  </div>

  <!-- Ini template hasil batch, hidden secara default -->
  <div id="result-batch-summary" class="card-body p-8 relative z-10 hidden flex-col items-center h-full">
    <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-4 shadow-inner shadow-primary/20">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
    </div>
    <h4 class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-1">Ringkasan Batch Prediksi</h4>
    <h2 id="batch-total-users" class="text-3xl font-extrabold text-primary mb-6 text-center leading-tight">0 Pelanggan</h2>
    
    <div class="w-full bg-base-100 rounded-xl p-5 border border-base-200 overflow-y-auto max-h-[200px]">
      <h5 class="text-[10px] font-bold uppercase tracking-widest text-base-content/50 mb-3 text-center">Distribusi Segmen</h5>
      <ul id="batch-distribution-list" class="space-y-2">
        <!-- List item akan dirender via JS -->
      </ul>
    </div>
    <p class="text-[10px] text-base-content/40 mt-6 text-center font-medium">Hasil prediksi lengkap dapat dilihat pada file CSV yang di-download.</p>
  </div>
</div>
