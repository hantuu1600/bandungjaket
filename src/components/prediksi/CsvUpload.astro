---
import { FolderUp, UploadCloud } from "@lucide/astro";
---

<div class="card glass-card hover-lift shadow-sm">
  <div class="card-body p-6 lg:p-8">
    <div class="flex items-center justify-between mb-8">
      <h3 class="card-title font-bold text-lg tracking-tight">
        Upload Data Batch (CSV)
      </h3>
      <div
        class="w-10 h-10 rounded-full bg-primary/5 flex items-center justify-center text-primary [&>svg]:w-5 [&>svg]:h-5"
      >
        <FolderUp />
      </div>
    </div>

    <!-- Drag-drop area -->
    <div
      id="dropzone"
      class="border-2 border-dashed border-base-300 hover:border-primary transition-colors duration-300 rounded-2xl p-10 text-center mb-6 bg-base-100/50 group cursor-pointer relative overflow-hidden flex flex-col items-center"
    >
      <input type="file" id="csvFileInput" accept=".csv" class="hidden" />
      <div
        class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
      >
      </div>
      <div
        class="w-16 h-16 bg-base-200 rounded-full flex items-center justify-center mb-4 group-hover:-translate-y-2 transition-transform duration-300 shadow-sm relative z-10 text-primary [&>svg]:w-8 [&>svg]:h-8 pointer-events-none"
      >
        <UploadCloud />
      </div>
      <p
        class="text-sm font-bold text-base-content/70 relative z-10 pointer-events-none mt-4"
      >
        Klik atau Drag & drop file CSV di sini
      </p>

      <div
        class="mt-4 inline-block bg-base-200/80 px-3 py-2 rounded-xl relative z-10 pointer-events-none"
      >
        <p
          class="text-[10px] font-semibold text-base-content/50 uppercase tracking-widest mb-1"
        >
          Format Kolom Wajib:
        </p>
        <code
          class="text-xs font-mono text-primary font-bold bg-transparent p-0"
          >username, recency, frequency, monetary</code
        >
      </div>
    </div>

    <!-- Action Area (Hidden by default, shown after file selection) -->
    <div id="action-area" class="hidden mt-6 flex flex-col space-y-4">
      <div class="bg-base-200 p-4 rounded-xl flex items-center justify-between border border-base-300">
        <div class="flex items-center space-x-3 overflow-hidden">
          <div class="w-10 h-10 bg-primary/10 text-primary rounded-lg flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <span id="selected-file-name" class="font-bold text-sm truncate">nama_file.csv</span>
        </div>
        <button id="btn-reselect" class="btn btn-sm btn-ghost text-base-content/60 hover:text-error shrink-0">Ganti</button>
      </div>
      
      <button
        id="btn-process-file"
        class="btn btn-primary w-full shadow-lg hover:shadow-primary/30 transition-all font-bold text-lg h-12"
      >
        Proses Data Sekarang
      </button>
    </div>

    <!-- Progress & Status Area (Hidden by default) -->
    <div
      id="processing-area"
      class="hidden flex flex-col items-center justify-center space-y-4 py-4"
    >
      <div
        class="w-full flex justify-between text-sm font-semibold text-base-content/70"
      >
        <span id="process-status">Memproses 0/0 baris...</span>
        <span id="process-percent">0%</span>
      </div>
      <progress
        id="process-progress"
        class="progress progress-primary w-full"
        value="0"
        max="100"></progress>
    </div>

    <!-- Download Area (Hidden by default) -->
    <div
      id="download-area"
      class="hidden flex flex-col items-center justify-center space-y-4 py-4 mt-4 border-t border-base-200"
    >
      <div
        class="w-12 h-12 bg-success/20 text-success rounded-full flex items-center justify-center mb-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 13l4 4L19 7"></path></svg
        >
      </div>
      <h4 class="font-bold text-lg">Proses Selesai!</h4>
      <button
        id="btn-download"
        class="btn btn-success text-white rounded-xl w-full"
      >
        Download Hasil (CSV)
      </button>
    </div>
  </div>
</div>

<script>
  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('csvFileInput') as HTMLInputElement;
  
  const actionArea = document.getElementById('action-area');
  const selectedFileName = document.getElementById('selected-file-name');
  const btnReselect = document.getElementById('btn-reselect');
  const btnProcess = document.getElementById('btn-process-file') as HTMLButtonElement;
  
  const processingArea = document.getElementById('processing-area');
  const processStatus = document.getElementById('process-status');
  const processPercent = document.getElementById('process-percent');
  const processProgress = document.getElementById('process-progress') as HTMLProgressElement;
  
  const downloadArea = document.getElementById('download-area');
  const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;

  // Elemen untuk ResultCard
  const resultEmpty = document.getElementById('result-empty');
  const resultSuccess = document.getElementById('result-success');
  const resultBatchSummary = document.getElementById('result-batch-summary');
  const batchTotalUsers = document.getElementById('batch-total-users');
  const batchDistributionList = document.getElementById('batch-distribution-list');

  let processedData: string[] = [];

  // Mapping Cluster ke Nama Segmen
  const getSegmentName = (clusterId: number) => {
    switch (clusterId) {
      case 0:
        return "Pelanggan Potensial";
      case 1:
        return "Pelanggan Dorman";
      case 2:
        return "Pelanggan Unggulan";
      case 3:
        return "Pelanggan Aktif";
      case 4:
        return "Pelanggan Berisiko Berhenti";
      case 5:
        return "Pelanggan Bernilai Terancam";
      default:
        return "Tidak Diketahui";
    }
  };

  if (dropzone && fileInput) {
    // Handle klik pada dropzone
    dropzone.addEventListener("click", () => {
      fileInput.click();
    });

    // Drag and Drop
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('border-primary', 'bg-primary/5');
    });

    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('border-primary', 'bg-primary/5');
    });

    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-primary', 'bg-primary/5');
      const dragEvent = e as DragEvent;
      if (dragEvent.dataTransfer && dragEvent.dataTransfer.files.length > 0) {
        fileInput.files = dragEvent.dataTransfer.files;
        handleFileSelect(fileInput.files[0]);
      }
    });

    fileInput.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.files && target.files.length > 0) {
        handleFileSelect(target.files[0]);
      }
    });

    if (btnReselect) {
      btnReselect.addEventListener('click', () => {
        fileInput.click();
      });
    }
  }

  const handleFileSelect = (file: File) => {
    if (!file.name.endsWith(".csv")) {
      alert("Tolong pilih file dengan format .csv");
      return;
    }

    if (selectedFileName) selectedFileName.textContent = file.name;
    
    // Sembunyikan dropzone, tampilkan action area
    if (dropzone && actionArea) {
      dropzone.classList.add("hidden");
      actionArea.classList.remove("hidden");
    }

    // Set tombol proses
    if (btnProcess) {
      btnProcess.onclick = () => {
        processCSV(file);
      };
    }
  };

  const processCSV = (file: File) => {
    // Tampilkan loading UI
    if (actionArea && processingArea) {
      actionArea.classList.add('hidden');
      processingArea.classList.remove('hidden');
    }

    // Ubah tampilan ResultCard di sebelah kanan ke mode Batch
    if (resultEmpty) resultEmpty.classList.add('hidden');
    if (resultSuccess) resultSuccess.classList.add('hidden');
    if (resultBatchSummary) {
      resultBatchSummary.classList.remove('hidden');
      resultBatchSummary.classList.add('flex');
    }
    if (batchTotalUsers) batchTotalUsers.textContent = `0 Pelanggan`;
    if (batchDistributionList) batchDistributionList.innerHTML = '';

    const reader = new FileReader();
    reader.onload = async (e) => {
      const text = e.target?.result as string;
      if (!text) return;
      const rows = text
        .split("\n")
        .map((row) => row.trim())
        .filter((row) => row);

      if (rows.length < 2) {
        alert("File CSV kosong atau tidak valid.");
        return;
      }

      // Mengambil Header
      const headerRaw = rows[0].split(",").map((h) => h.trim().toLowerCase());

      // Pastikan ada username, recency, frequency, monetary
      const required = ["username", "recency", "frequency", "monetary"];
      const missing = required.filter((r) => !headerRaw.includes(r));

      if (missing.length > 0) {
        alert(`CSV tidak valid. Kolom yang kurang: ${missing.join(", ")}`);
        // Reset UI
        if (processingArea && dropzone && actionArea) {
          processingArea.classList.add("hidden");
          dropzone.classList.remove("hidden");
          actionArea.classList.add("hidden");
        }
        return;
      }

      // Ekstrak Indeks Kolom
      const idx: Record<string, number> = {};
      required.forEach((r) => {
        idx[r] = headerRaw.indexOf(r);
      });

      processedData = [];
      // Buat header baru untuk output
      processedData.push(
        "username,recency,frequency,monetary,cluster_id,segment_name,umap_x,umap_y",
      );

      const dataRows = rows.slice(1);
      const total = dataRows.length;

      // Batasi 1000 baris agar tidak membebani browser (opsional)
      const maxRows = Math.min(total, 1000);

      if (processProgress) processProgress.max = maxRows;

      const segmentCounts: Record<string, number> = {};

      // Loop pengiriman request (Menggunakan Promise untuk menahan laju request)
      for (let i = 0; i < maxRows; i++) {
        const cols = dataRows[i].split(",").map((c) => c.trim());
        if (cols.length < headerRaw.length) continue; // Skip jika kolom tidak lengkap

        const username = cols[idx['username']];
        const recency = parseInt(cols[idx['recency']]);
        const frequency = parseInt(cols[idx['frequency']]);
        const monetary = parseFloat(cols[idx['monetary']]);

        try {
          const res = await fetch(
            "https://hantuu16-data-bandungjaket.hf.space/api/predict",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ recency, frequency, monetary }),
            },
          );

          if (res.ok) {
            const result = await res.json();
            const segment = getSegmentName(result.cluster_id);
            // Tambah hasil ke csv baru
            processedData.push(
              `${username},${recency},${frequency},${monetary},${result.cluster_id},${segment},${result.umap_x},${result.umap_y}`,
            );

            // Update stats
            segmentCounts[segment] = (segmentCounts[segment] || 0) + 1;

          } else {
            // Jika gagal prediksi baris ini
            processedData.push(
              `${username},${recency},${frequency},${monetary},ERROR,ERROR,0,0`,
            );
          }
        } catch (error) {
          processedData.push(
            `${username},${recency},${frequency},${monetary},ERROR,ERROR,0,0`,
          );
        }

        // Update UI Progress
        const current = i + 1;
        const percent = Math.round((current / maxRows) * 100);
        if (processStatus) processStatus.textContent = `Memproses ${current} / ${maxRows} baris...`;
        if (processPercent) processPercent.textContent = `${percent}%`;
        if (processProgress) processProgress.value = current;

        // Update Card Sebelah Kanan (Real-time!)
        if (batchTotalUsers) batchTotalUsers.textContent = `${current} Pelanggan`;
        if (batchDistributionList) {
          batchDistributionList.innerHTML = Object.entries(segmentCounts)
            .sort((a, b) => b[1] - a[1]) // Urutkan dari yang terbanyak
            .map(([name, count]) => `
              <li class="flex justify-between items-center bg-base-200/50 rounded-lg p-2 px-3">
                <span class="text-xs font-semibold text-base-content/80">${name}</span>
                <span class="badge badge-primary badge-sm font-bold">${count}</span>
              </li>
            `).join('');
        }
      }

      // Setelah selesai
      if (processingArea && downloadArea && btnDownload) {
        processingArea.classList.add("hidden");
        downloadArea.classList.remove("hidden");

        btnDownload.onclick = () => {
          downloadCSV(
            processedData.join("\n"),
            `Segmentasi_Result_${new Date().getTime()}.csv`,
          );
        };
      }
    };

    reader.readAsText(file);
  };

  const downloadCSV = (csvContent: string, fileName: string) => {
    const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.setAttribute("href", url);
    link.setAttribute("download", fileName);
    link.style.visibility = "hidden";
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };
</script>
