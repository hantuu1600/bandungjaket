---
import { LayoutDashboard, Search, BookOpen } from '@lucide/astro'

interface Props {
  activePage: string
}
const { activePage } = Astro.props

const menuItems = [
  { id: 'dashboard', label: 'Analisis Segmen', icon: LayoutDashboard, route: '/dashboard' },
  { id: 'prediksi', label: 'Klasifikasi Pelanggan', icon: Search, route: '/prediksi' },
  { id: 'tentang', label: 'Metodologi & Strategi', icon: BookOpen, route: '/tentang' },
]
---
<div class="px-6 pt-8 pb-4 mb-4">
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 rounded-xl bg-primary flex items-center justify-center shadow-lg shadow-primary/30">
      <span class="text-white font-bold text-sm">BJ</span>
    </div>
    <div>
      <h1 class="text-sm font-bold text-primary leading-none">CRM Analytics</h1>
      <p class="text-[10px] text-base-content/50 mt-1 uppercase tracking-wider font-semibold">bandungjaket.com</p>
    </div>
  </div>
</div>

<div class="px-4 flex-1">
  <ul class="menu w-full p-0 gap-1">
    {menuItems.map(item => {
      const isActive = activePage === item.id;
      const Icon = item.icon;
      return (
        <li>
          <a href={item.route} class={`px-4 py-3 rounded-xl transition-all duration-300 ${isActive ? 'bg-primary text-white shadow-md shadow-primary/20 scale-105 active:!bg-primary' : 'hover:bg-base-200 text-base-content/70 hover:text-primary hover-lift'}`}>
            <span class="mr-2 [&>svg]:w-5 [&>svg]:h-5"><Icon /></span>
            <span class={`text-sm font-medium ${isActive ? 'font-semibold' : ''}`}>{item.label}</span>
          </a>
        </li>
      )
    })}
  </ul>
</div>

<div class="p-6 mt-auto">
  <a href="/" class="btn btn-outline btn-block border-2 border-base-300 hover:border-primary hover:bg-primary/5 text-base-content/70 hover:text-primary group hover-lift rounded-xl">
    <span class="group-hover:-translate-x-1 transition-transform">←</span>
    Beranda
  </a>
</div>
