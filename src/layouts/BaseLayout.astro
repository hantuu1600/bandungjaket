---
import '../assets/app.css';
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/navigation/Sidebar.astro';
import BottomTabs from '../components/navigation/BottomTabs.astro';
import TopNavbar from '../components/navigation/TopNavbar.astro';

interface Props {
  title: string
  activePage: 'overview' | 'dashboard' | 'prediksi' | 'tentang'
}
const { title, activePage } = Astro.props
const isLanding = activePage === 'overview'
---
<html lang="id" data-theme="bandungjaket">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <ClientRouter />
</head>
<body class="min-h-screen selection:bg-accent/30 text-base-content font-sans">

  {isLanding ? (
    <!-- LANDING LAYOUT (Overview page) -->
    <div>
      <TopNavbar />
      <main transition:name="main-content">
        <slot />
      </main>
    </div>
  ) : (
    <!-- APP LAYOUT (Dashboard, Prediksi, Tentang) -->
    <div class="flex min-h-screen">
      <!-- Sidebar desktop -->
      <aside class="hidden lg:flex lg:flex-col lg:w-64 lg:min-h-screen bg-base-100/80 backdrop-blur-sm border-r border-base-300 shadow-sm z-20">
        <Sidebar activePage={activePage} />
      </aside>

      <div class="flex-1 flex flex-col max-h-screen overflow-hidden">
        <!-- Desktop header -->
        <header class="sticky top-0 z-10 hidden lg:block bg-base-100/90 backdrop-blur-sm border-b border-base-300 shadow-sm">
          <div class="px-8 py-4 flex items-center justify-between">
            <div class="font-semibold text-lg text-primary">{title}</div>
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-primary to-accent text-white flex items-center justify-center text-xs font-bold shadow-md">FR</div>
            </div>
          </div>
        </header>

        <!-- Mobile top navbar -->
        <div class="lg:hidden">
          <TopNavbar />
        </div>

        <main class="flex-1 overflow-y-auto p-4 lg:p-8 pb-28 lg:pb-12 scroll-smooth">
          <div class="max-w-6xl mx-auto w-full fade-in-up" transition:animate="fade">
            <slot />
          </div>
        </main>
      </div>
    </div>
  )}

  <!-- Bottom tabs mobile -->
  {!isLanding && (
    <nav transition:persist class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-base-100 border-t border-base-300 h-16 flex items-center shadow-[0_-4px_20px_rgba(0,0,0,0.05)]">
      <BottomTabs activePage={activePage} />
    </nav>
  )}

</body>
</html>
